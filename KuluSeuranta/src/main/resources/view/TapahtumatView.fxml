<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TapahtumatController">
   <center>
      <TableView fx:id="tapahtumaTable" prefHeight="350.0" prefWidth="650.0" BorderPane.alignment="CENTER">
        <columns>
            <TableColumn fx:id="nimiColumn" prefWidth="180.0" text="Nimi" />
          <TableColumn fx:id="summaColumn" prefWidth="120.0" text="Summa" />
          <TableColumn fx:id="pvmColumn" prefWidth="140.0" text="Päivämäärä" />
            <TableColumn fx:id="kategoriaColumn" prefWidth="180.0" text="Kategoria" />
        </columns>
      </TableView>
   </center>
   <right>
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="140.0" spacing="10.0" BorderPane.alignment="TOP_LEFT">
         <children>
            <Label text="Toiminnot">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <TextField fx:id="nimiText" promptText="Nimi" />
            <TextField fx:id="summaText" promptText="Summa" />
            <DatePicker fx:id="pvmPicker" />
            <ComboBox fx:id="lisaysKategoriaCombo" prefWidth="150.0" promptText="Kategoria" />
            <Button fx:id="lisaaTuloBtn" mnemonicParsing="false" onAction="#handleLisaaTulo" prefWidth="100.0" text="Lisää tulo" />
            <Button fx:id="lisaaMenoBtn" mnemonicParsing="false" onAction="#handleLisaaMeno" prefWidth="100.0" text="Lisää meno" />
            <Button fx:id="muokkaaBtn" mnemonicParsing="false" onAction="#handleMuokkaa" prefWidth="100.0" text="Muokkaa">
               <VBox.margin>
                  <Insets top="15.0" />
               </VBox.margin></Button>
            <Button fx:id="poistaBtn" mnemonicParsing="false" onAction="#handlePoista" prefWidth="100.0" text="Poista" />
            <Button fx:id="kategoriatBtn" mnemonicParsing="false" onAction="#handleKategoriat" prefWidth="100.0" text="Kategoriat">
               <VBox.margin>
                  <Insets top="15.0" />
               </VBox.margin></Button>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </right>
   <bottom>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="30.0" BorderPane.alignment="CENTER_LEFT">
         <children>
            <Label text="Tulot:">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <Label fx:id="tulotLabel" text="0 €" textFill="#00aa03">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <Label text="Menot:">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <Label fx:id="menotLabel" text="0 €" textFill="RED">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <Label text="Saldo:">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <Label fx:id="saldoLabel" text="0 €">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </HBox>
   </bottom>
   <top>
      <VBox prefHeight="100.0" prefWidth="100.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Kuluseuranta">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Label text="Alku:" />
                  <DatePicker fx:id="alkuPvmPicker" />
                  <Label text="Loppu:" />
                  <DatePicker fx:id="loppuPvmPicker" />
                  <Label text="Kategoria:" />
                  <ComboBox fx:id="kategoriaCombo" prefWidth="150.0" promptText="Kaikki" />
                  <Button fx:id="haeBtn" mnemonicParsing="false" onAction="#handleHae" prefWidth="100.0" text="Hae" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </VBox>
