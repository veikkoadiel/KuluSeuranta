<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0"
            prefWidth="600.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.KategoriatController">

   <top>
      <Label text="Kategoriat" BorderPane.alignment="CENTER_LEFT">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
         <padding>
            <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
         </padding>
      </Label>
   </top>

   <center>
      <TableView fx:id="kategoriaTable">
         <columns>
            <TableColumn fx:id="kategoriaColumn"
                         prefWidth="250.0"
                         text="Kategoria" />
         </columns>
      </TableView>
   </center>

   <right>
      <VBox alignment="TOP_CENTER"
            spacing="10.0"
            prefWidth="140.0"
            BorderPane.alignment="CENTER">

         <children>
            <Button fx:id="lisaaKategoriaBtn"
                    text="Lisää kategoria"
                    prefWidth="110.0"
                    onAction="#handleLisaaKategoria" />

            <Button fx:id="muokkaaBtn"
                    text="Muokkaa"
                    prefWidth="110.0"
                    onAction="#handleMuokkaaKategoria" />

            <Button fx:id="poistaBtn"
                    text="Poista"
                    prefWidth="110.0"
                    onAction="#handlePoistaKategoria" />

            <Button fx:id="takaisinBtn"
                    text="Takaisin"
                    prefWidth="110.0"
                    onAction="#handleTakaisin" />
         </children>

         <padding>
            <Insets top="20.0" />
         </padding>
      </VBox>
   </right>

   <bottom>
      <Label text="* = Pakollinen meno"
             BorderPane.alignment="CENTER_RIGHT">

         <padding>
            <Insets top="10.0"
                    right="10.0"
                    bottom="10.0"
                    left="10.0" />
         </padding>
      </Label>
   </bottom>

</BorderPane>