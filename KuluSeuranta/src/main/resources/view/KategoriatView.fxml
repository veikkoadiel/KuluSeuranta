<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.KategoriatController">

   <top>
      <Label text="Kategoriat" BorderPane.alignment="CENTER_LEFT">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </Label>
   </top>

   <center>
      <TableView fx:id="kategoriaTable">
         <columns>
            <TableColumn fx:id="kategoriaColumn" prefWidth="250.0" text="Kategoria" />
         </columns>
      </TableView>
   </center>

   <right>
      <VBox alignment="TOP_CENTER" prefWidth="140.0" BorderPane.alignment="CENTER">

         <children>
            <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0">
               <children>
                  <TextField fx:id="kategoriaText" prefWidth="120.0" promptText="Kategorian nimi">
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </TextField>
                   <CheckBox fx:id="valttamatonCheck" text="Välttämätön meno" />
                  <Button fx:id="lisaaKategoriaBtn" onAction="#handleLisaaKategoria" prefWidth="100.0" text="Lisää kategoria" />
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <padding>
                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </padding>
            </VBox>
            <VBox alignment="BOTTOM_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0">
               <children>

                  <Button fx:id="muokkaaBtn" onAction="#handleMuokkaaKategoria" prefWidth="110.0" text="Muokkaa" />

                  <Button fx:id="poistaBtn" onAction="#handlePoistaKategoria" prefWidth="110.0" text="Poista" />
      
                  <Button fx:id="takaisinBtn" onAction="#handleTakaisin" prefWidth="110.0" text="Takaisin" />
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </right>

   <bottom>
      <Label text="* = Pakollinen meno" BorderPane.alignment="CENTER_RIGHT">

         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </Label>
   </bottom>

</BorderPane>
